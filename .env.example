# ══════════════════════════════════════════════════════════════════════════════
#  Agentic GraphRAG — Environment Configuration
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Options: "openai" | "anthropic" | "local"
LLM_PROVIDER=local

# Local model (used when LLM_PROVIDER=local)
LOCAL_MODEL_ID=Qwen/Qwen2.5-3B-Instruct

# API Keys for Cloud Providers
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GROQ_API_KEY=your_groq_api_key_here
OPENAI_MODEL=gpt-4o

# Anthropic (used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ── LLM Parameters ──────────────────────────────────────────────────────────
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=256

# ── Retrieval ────────────────────────────────────────────────────────────────
DEFAULT_STRATEGY=fusion_all
ENABLE_QUERY_EXPANSION=true

# ── Qdrant ───────────────────────────────────────────────────────────────────
# Mode: "local" (file-based, default) or "server" (Docker Qdrant instance)
QDRANT_MODE=local
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ── Hugging Face ─────────────────────────────────────────────────────────────
# Set to 0 on first run to download models, then 1 for faster startup
HF_HUB_OFFLINE=0

# ── FastAPI ──────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Streamlit ────────────────────────────────────────────────────────────────
STREAMLIT_PORT=8501

# ── RAGAS / LangSmith (optional) ─────────────────────────────────────────────
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=graphrag-eval

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO